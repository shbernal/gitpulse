#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 org/repo" >&2
  exit 1
fi

API="https://api.github.com/repos/$1"
ORG=${1%%/*}
REPO=${1#*/}

json=$(curl -sS "$API")

created_at=$(jq -r '.created_at' <<<"$json")
created_at_fmt=$(date -d "$created_at" +%d/%m/%Y 2>/dev/null || echo "$created_at")
stars=$(jq -r '.stargazers_count' <<<"$json")
stars_fmt=$(awk -v v="$stars" 'BEGIN {if (v >= 1000) printf "%.1fk", v/1000; else printf "%s", v}')
lang=$(jq -r '.language // "N/A"' <<<"$json")
forks=$(jq -r '.forks_count' <<<"$json")
issues=$(jq -r '.open_issues' <<<"$json")

BOLD=$'\033[1m'
CYAN=$'\033[36m'
YELLOW=$'\033[33m'
GREEN=$'\033[32m'
MAGENTA=$'\033[35m'
BLUE=$'\033[34m'
RED=$'\033[31m'
RESET=$'\033[0m'

MIN_SEP=10

header_len=$(( ${#ORG} + 1 + ${#REPO} ))
max_len=$header_len

labels=(
  "Created at"
  $'\uf41e Stars'
  "Language"
  $'\uea63 Forks'
  $'\ueb0c Issues'
)
values=(
  "$created_at_fmt"
  "$stars_fmt"
  "$lang"
  "$forks"
  "$issues"
)

# Get widest printable content (label + min_sep + value)
for i in "${!labels[@]}"; do
  line_len=$(( ${#labels[$i]} + MIN_SEP + ${#values[$i]} ))
  (( line_len > max_len )) && max_len=$line_len
done

draw_border() {
  local width=$1
  printf "+-%-${width}s-+\n" "" | sed 's/ /-/g'
}

line() {
  local color=$1 label=$2 value=$3 width=$4
  local gap=$(( width - (${#label} + ${#value}) ))
  (( gap < MIN_SEP )) && gap=$MIN_SEP
  printf "| %s%s%s%*s%s |\n" "$color" "$label" "$RESET$BOLD" "$gap" "" "$value"
}

printf "%s" "$BOLD"
draw_border "$max_len"
printf "| %s%-*s%s |\n" "$CYAN" "$max_len" "$ORG/$REPO" "$RESET$BOLD"
draw_border "$max_len"
line "$BLUE"   "${labels[0]}" "${values[0]}" "$max_len"
line "$YELLOW" "${labels[1]}" "${values[1]}" "$max_len"
line "$GREEN"  "${labels[2]}" "${values[2]}" "$max_len"
line "$MAGENTA" "${labels[3]}" "${values[3]}" "$max_len"
line "$RED"   "${labels[4]}" "${values[4]}" "$max_len"
draw_border "$max_len"
printf "%s" "$RESET"
